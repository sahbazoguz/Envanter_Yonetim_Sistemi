@model Personel
@{
    ViewData["Title"] = "Personel Detayı";
    var roller = ViewData["Roller"] as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<h1>@ViewData["Title"]</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Ad Soyad</dt>
            <dd class="col-sm-9">@Model.AdSoyad</dd>
            <dt class="col-sm-3">E-posta</dt>
            <dd class="col-sm-9">@Model.Email</dd>
            <dt class="col-sm-3">Sicil No</dt>
            <dd class="col-sm-9">@Model.SicilNo</dd>
            <dt class="col-sm-3">Roller</dt>
            <dd class="col-sm-9">@string.Join(", ", roller)</dd>
        </dl>
    </div>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning mt-3">Düzenle</a>
<a asp-action="Index" class="btn btn-secondary mt-3">Listeye Dön</a>
