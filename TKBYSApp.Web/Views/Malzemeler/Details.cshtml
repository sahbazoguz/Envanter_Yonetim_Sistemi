@model Malzeme
@{
    ViewData["Title"] = "Malzeme Detayı";
}

<h1>@ViewData["Title"]</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Barkod</dt>
            <dd class="col-sm-9">@Model.BarKod</dd>
            <dt class="col-sm-3">Cinsi</dt>
            <dd class="col-sm-9">@Model.Cinsi</dd>
            <dt class="col-sm-3">Marka</dt>
            <dd class="col-sm-9">@Model.MarkaAdi</dd>
            <dt class="col-sm-3">Model</dt>
            <dd class="col-sm-9">@Model.Modeli</dd>
            <dt class="col-sm-3">Seri No</dt>
            <dd class="col-sm-9">@Model.SeriNo</dd>
            <dt class="col-sm-3">Ölçü</dt>
            <dd class="col-sm-9">@Model.OlcuAdi</dd>
            <dt class="col-sm-3">Sicil No</dt>
            <dd class="col-sm-9">@Model.SicilNo</dd>
            <dt class="col-sm-3">Fis No</dt>
            <dd class="col-sm-9">@Model.FisNo</dd>
            <dt class="col-sm-3">Fiş Son Durumu</dt>
            <dd class="col-sm-9">@Model.FisSonDurum</dd>
            <dt class="col-sm-3">Verildiği Yer/Birim</dt>
            <dd class="col-sm-9">@Model.VerildigiYerBirim</dd>
            <dt class="col-sm-3">TC Numarası</dt>
            <dd class="col-sm-9">@Model.TcNumarasi</dd>
            <dt class="col-sm-3">Ambar</dt>
            <dd class="col-sm-9">@Model.AmbarAdi ?? Model.Depo?.Ad</dd>
            <dt class="col-sm-3">Durum</dt>
            <dd class="col-sm-9">@Model.Durum</dd>
            <dt class="col-sm-3">Kurum Giriş Tarihi</dt>
            <dd class="col-sm-9">@Model.KurumGirisTarihi?.ToString("f")</dd>
            <dt class="col-sm-3">Tarih</dt>
            <dd class="col-sm-9">@Model.Tarih?.ToString("f")</dd>
            <dt class="col-sm-3">Ad</dt>
            <dd class="col-sm-9">@Model.Ad</dd>
            <dt class="col-sm-3">TKBYS No</dt>
            <dd class="col-sm-9">@Model.TKBYSNo</dd>
            <dt class="col-sm-3">Özellikler</dt>
            <dd class="col-sm-9">@Model.Ozellikler</dd>
            <dt class="col-sm-3">Ek Özellik</dt>
            <dd class="col-sm-9">@Model.EkOzellik</dd>
            <dt class="col-sm-3">Açıklama</dt>
            <dd class="col-sm-9">@Model.Aciklama</dd>
            <dt class="col-sm-3">Adet</dt>
            <dd class="col-sm-9">@Model.Adet</dd>
            <dt class="col-sm-3">Kayıt Tarihi</dt>
            <dd class="col-sm-9">@Model.KayitTarihi.ToLocalTime().ToString("f")</dd>
        </dl>
    </div>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning mt-3">Düzenle</a>
<a asp-action="Index" class="btn btn-secondary mt-3">Listeye Dön</a>
