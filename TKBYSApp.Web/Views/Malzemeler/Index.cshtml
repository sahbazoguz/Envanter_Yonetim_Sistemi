@model IEnumerable<Malzeme>
@{
    ViewData["Title"] = "Malzemeler";
}

<h1>Malzemeler</h1>
<p>
    <a class="btn btn-primary" asp-action="Create">Yeni Malzeme</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Ad</th>
            <th>TKBYS No</th>
            <th>Depo</th>
            <th>Adet</th>
            <th>Durum</th>
            <th>Kayıt Tarihi</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Ad</td>
            <td>@item.TKBYSNo</td>
            <td>@item.Depo?.Ad</td>
            <td>@item.Adet</td>
            <td>@item.Durum</td>
            <td>@item.KayitTarihi.ToLocalTime().ToString("g")</td>
            <td class="text-end">
                <a class="btn btn-sm btn-secondary" asp-action="Details" asp-route-id="@item.Id">Detay</a>
                <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id">Sil</a>
            </td>
        </tr>
}
    </tbody>
</table>
